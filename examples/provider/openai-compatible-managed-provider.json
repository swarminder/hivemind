{
  "host": "127.0.0.1",
  "port": 8788,
  "securityMode": "local-dev",
  "providerId": "provider-local",
  "displayName": "Managed Local LLM Provider",
  "modelId": "local-llama",
  "modelDisplayName": "Local OpenAI-Compatible LLM",
  "backendType": "openai-compatible-http",
  "backendModelId": "llama3.2",
  "backendBaseUrl": "http://127.0.0.1:11434/v1",
  "backendTimeoutSeconds": 120,
  "backendStartCommand": "ollama",
  "backendStartArgs": [
    "serve"
  ],
  "backendHealthUrl": "http://127.0.0.1:11434/api/tags",
  "maxDebt": 100.0,
  "forgivenessPerSecond": 5.0,
  "pricePerInputToken": 0.001,
  "pricePerOutputToken": 0.002,
  "pricePerModelSecond": 0.01,
  "pricePerRequest": 0.1,
  "statePath": ".swarm-ai-cache/provider/managed-openai-state.json",
  "maxConcurrentSessions": 8,
  "maxConcurrentJobs": 1,
  "maxContextTokens": 8192,
  "maxOutputTokens": 1024,
  "maxPromptBytes": 262144,
  "maxPromptMessages": 64,
  "maxModelStartsPerHour": 4,
  "maxColdStartSeconds": 30,
  "initialModelState": "available_cold"
}
